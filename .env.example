# ──────────────────────────────────────────────────────────────────────────────
# Foundry Local Nemotron Voice Assistant — environment template
# Copy this file to .env and fill in any values you want to override.
# All values shown here are the defaults — the app works without this file.
# ──────────────────────────────────────────────────────────────────────────────

# ── Model selection ───────────────────────────────────────────────────────────
# Run `python src/utils.py --list-models` to see all available models.
NEMOTRON_MODEL=qwen2.5-0.5b
WHISPER_MODEL=whisper-base

# ── Nemotron generation parameters ────────────────────────────────────────────
MAX_TOKENS=256
TEMPERATURE=0.7
STREAM_RESPONSE=true

# ── Whisper transcription ─────────────────────────────────────────────────────
WHISPER_LANGUAGE=en

# ── System prompt (overrides the default voice-assistant prompt) ───────────────
# SYSTEM_PROMPT=You are a helpful assistant. Keep answers under 3 sentences.

# ── Conversation history ──────────────────────────────────────────────────────
HISTORY_LIMIT=10

# ── Audio recording ───────────────────────────────────────────────────────────
# AUDIO_TEMP_DIR=audio_samples        # directory for temporary WAV files
# SILENCE_THRESHOLD=0.01              # RMS below this = silence (0.0–1.0)
# SILENCE_DURATION=1.5                # seconds of silence before auto-stop
# RECORD_SECONDS=5.0                  # maximum recording window
# DEVICE_INDEX=                       # leave blank for system default mic
#                                     # run `python src/utils.py --list-mics` to find indices

# ── Text-to-speech ────────────────────────────────────────────────────────────
TTS_ENGINE=pyttsx3                    # pyttsx3 (offline) | edge-tts (online, neural)
TTS_RATE=175                          # words per minute (pyttsx3)
TTS_VOLUME=0.9                        # 0.0 – 1.0 (pyttsx3)
# TTS_VOICE=                          # partial name match for pyttsx3 voice
EDGE_TTS_VOICE=en-US-AriaNeural       # used only when TTS_ENGINE=edge-tts

# ── Wake word (optional) ──────────────────────────────────────────────────────
# Leave blank to use press-to-talk / VAD mode.
# WAKE_WORD=hey nemotron

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
